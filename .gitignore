# =========================================================
# Rust / Cargo
# =========================================================

# Cargo build output
/target/

# Rust backup files sometimes produced by tooling
**/*.rs.bk


# =========================================================
# Project Build / Packaging Artifacts
# =========================================================

# Local build staging / generated outputs
/dist/
/results/

# Release archives
*.tar.gz
*.zip


# =========================================================
# Local-Only Project Working Data
# =========================================================

# Tool caches and ephemeral local data
/.cache/

# Research / task packet working folders - heavy churn and messy
/PHASE2_RESEARCH/
/TASK_PACKETS/


# =========================================================
# Python / Documentation Tooling
# =========================================================

# Virtual environments
/.venv/
/venv/
/env/

# Python bytecode / cache
__pycache__/
*.py[cod]

# Static site output (MkDocs)
/site/


# =========================================================
# Editors / IDEs
# =========================================================

# JetBrains
/.idea/

# VS Code
/.vscode/

# Vim / generic editor temp files
*.swp
*.swo
*~


# =========================================================
# Logs / Temporary Files
# =========================================================

*.log
*.tmp
*.temp


# =========================================================
# OS Noise
# =========================================================

.DS_Store
Thumbs.db
