{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crushr.dev/schemas/crushr-lab-salvage-format12-stress-comparison.v2.schema.json",
  "type": "object",
  "required": ["schema_version", "scenario_count", "variants", "by_variant", "grouped_breakdown", "per_scenario_rows", "datasets", "deterministic_seed_start"],
  "properties": {
    "schema_version": { "const": "crushr-lab-salvage-format12-stress-comparison.v2" },
    "scenario_count": { "type": "integer", "minimum": 0 },
    "variants": {
      "type": "array",
      "items": { "enum": ["payload_only", "extent_identity_only", "extent_identity_distributed_names", "payload_plus_manifest", "full_current_experimental", "extent_identity_inline_path"] }
    },
    "by_variant": { "type": "object" },
    "grouped_breakdown": { "type": "object" },
    "per_scenario_rows": { "type": "array", "items": { "type": "object" } },
    "datasets": { "type": "array", "items": { "type": "string" } },
    "deterministic_seed_start": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
