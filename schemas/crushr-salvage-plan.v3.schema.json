{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.crushr.dev/crushr-salvage-plan.v3.schema.json",
  "title": "crushr salvage plan v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool",
    "tool_version",
    "verification_contract_label",
    "archive",
    "footer_analysis",
    "index_analysis",
    "redundant_map_analysis",
    "bootstrap_anchor_analysis",
    "dictionary_analysis",
    "block_candidates",
    "file_plans",
    "orphan_candidate_summary",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "crushr-salvage-plan.v3"
    },
    "tool": {
      "const": "crushr-salvage"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "verification_contract_label": {
      "const": "UNVERIFIED_RESEARCH_OUTPUT_NOT_CANONICAL_EXTRACTION"
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archive_path",
        "archive_size",
        "archive_blake3"
      ],
      "properties": {
        "archive_path": {
          "type": "string",
          "minLength": 1
        },
        "archive_size": {
          "type": "integer",
          "minimum": 0
        },
        "archive_blake3": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "footer_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "blocks_end_offset",
        "footer_offset"
      ],
      "properties": {
        "status": {
          "enum": [
            "valid",
            "invalid",
            "missing"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "blocks_end_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "footer_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "index_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "index_offset",
        "index_len",
        "entry_count"
      ],
      "properties": {
        "status": {
          "enum": [
            "valid",
            "invalid",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "index_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "index_len": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "entry_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "dictionary_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "verified_dict_ids"
      ],
      "properties": {
        "status": {
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "verified_dict_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "block_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scan_offset",
          "mapped_block_id",
          "structural_status",
          "header_status",
          "header_reason",
          "payload_bounds_status",
          "payload_hash_status",
          "dictionary_required",
          "dictionary_id",
          "dictionary_dependency_status",
          "decompression_status",
          "raw_hash_status",
          "content_verification_status",
          "content_verification_reasons",
          "usable_for_indexed_planning",
          "verified_raw_len"
        ],
        "properties": {
          "scan_offset": {
            "type": "integer",
            "minimum": 0
          },
          "mapped_block_id": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "structural_status": {
            "const": "detected"
          },
          "header_status": {
            "enum": [
              "valid",
              "invalid"
            ]
          },
          "header_reason": {
            "type": "string",
            "minLength": 1
          },
          "payload_bounds_status": {
            "enum": [
              "in_bounds",
              "out_of_bounds",
              "unknown"
            ]
          },
          "payload_hash_status": {
            "enum": [
              "verified",
              "mismatch",
              "unavailable"
            ]
          },
          "dictionary_required": {
            "type": "boolean"
          },
          "dictionary_id": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "dictionary_dependency_status": {
            "enum": [
              "not_required",
              "satisfied",
              "missing",
              "invalid",
              "unresolved"
            ]
          },
          "decompression_status": {
            "enum": [
              "not_attempted",
              "success",
              "failed",
              "unsupported_codec"
            ]
          },
          "raw_hash_status": {
            "enum": [
              "verified",
              "mismatch",
              "unavailable",
              "not_attempted"
            ]
          },
          "content_verification_status": {
            "enum": [
              "content_verified",
              "not_content_verified"
            ]
          },
          "content_verification_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "all_required_checks_passed",
                "decompression_not_successful",
                "dictionary_dependency_unsatisfied",
                "header_invalid",
                "header_out_of_bounds",
                "header_prefix_out_of_bounds",
                "manifest_digest_not_verified",
                "manifest_expected_blocks_missing",
                "manifest_without_recoverable_extents",
                "no_required_blocks",
                "payload_block_identity_index_gap",
                "payload_block_identity_missing_required_block_coverage",
                "payload_hash_mismatch",
                "payload_out_of_bounds",
                "raw_hash_mismatch",
                "required_block_not_content_verified",
                "required_block_unmapped",
                "required_extent_out_of_bounds"
              ]
            }
          },
          "usable_for_indexed_planning": {
            "type": "boolean"
          },
          "verified_raw_len": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        }
      }
    },
    "file_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file_path",
          "status",
          "reason",
          "failure_reasons",
          "required_block_ids",
          "mapping_provenance",
          "recovery_classification"
        ],
        "properties": {
          "file_path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "SALVAGEABLE",
              "UNSALVAGEABLE",
              "UNMAPPABLE"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "failure_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "all_required_checks_passed",
                "decompression_not_successful",
                "dictionary_dependency_unsatisfied",
                "header_invalid",
                "header_out_of_bounds",
                "header_prefix_out_of_bounds",
                "manifest_digest_not_verified",
                "manifest_expected_blocks_missing",
                "manifest_without_recoverable_extents",
                "no_required_blocks",
                "payload_block_identity_index_gap",
                "payload_block_identity_missing_required_block_coverage",
                "payload_hash_mismatch",
                "payload_out_of_bounds",
                "raw_hash_mismatch",
                "required_block_not_content_verified",
                "required_block_unmapped",
                "required_extent_out_of_bounds"
              ]
            }
          },
          "required_block_ids": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            }
          },
          "mapping_provenance": {
            "enum": [
              "PRIMARY_INDEX_PATH",
              "REDUNDANT_VERIFIED_MAP_PATH",
              "CHECKPOINT_MAP_PATH",
              "SELF_DESCRIBING_EXTENT_PATH",
              "FILE_MANIFEST_PATH",
              "FILE_IDENTITY_EXTENT_PATH",
              "FILE_IDENTITY_EXTENT_PATH_ANONYMOUS",
              "PAYLOAD_BLOCK_IDENTITY_PATH",
              "PAYLOAD_BLOCK_IDENTITY_PATH_ANONYMOUS"
            ]
          },
          "recovery_classification": {
            "enum": [
              "FULL_VERIFIED",
              "FULL_ANONYMOUS",
              "PARTIAL_ORDERED",
              "PARTIAL_UNORDERED",
              "ORPHAN_BLOCKS"
            ]
          }
        }
      }
    },
    "orphan_candidate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_candidates",
        "usable_candidates",
        "mapped_candidates",
        "orphan_unmappable_candidates"
      ],
      "properties": {
        "total_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "usable_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "mapped_candidates": {
          "type": "integer",
          "minimum": 0
        },
        "orphan_unmappable_candidates": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "salvageable_files",
        "unsalvageable_files",
        "unmappable_files"
      ],
      "properties": {
        "salvageable_files": {
          "type": "integer",
          "minimum": 0
        },
        "unsalvageable_files": {
          "type": "integer",
          "minimum": 0
        },
        "unmappable_files": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "exported_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exported_block_artifacts",
        "exported_fragment_artifacts",
        "exported_complete_file_artifacts"
      ],
      "properties": {
        "exported_block_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exported_fragment_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exported_complete_file_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "redundant_map_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "file_count"
      ],
      "properties": {
        "status": {
          "enum": [
            "valid",
            "invalid",
            "missing",
            "unavailable",
            "not_used"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "file_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "bootstrap_anchor_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "verified_anchor_count"
      ],
      "properties": {
        "status": {
          "enum": [
            "available",
            "missing",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "verified_anchor_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
