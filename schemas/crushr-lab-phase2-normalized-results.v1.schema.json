{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crushr.dev/schemas/crushr-lab-phase2-normalized-results.v1.schema.json",
  "title": "crushr-lab phase2 normalized results v1",
  "type": "array",
  "items": {
    "$ref": "#/$defs/normalized_run_record"
  },
  "$defs": {
    "dataset": {
      "enum": [
        "smallfiles",
        "mixed",
        "largefiles"
      ]
    },
    "archive_format": {
      "enum": [
        "crushr",
        "zip",
        "tar+zstd",
        "tar+gz",
        "tar+xz"
      ]
    },
    "corruption_type": {
      "enum": [
        "bit_flip",
        "byte_overwrite",
        "zero_fill",
        "truncation",
        "tail_damage"
      ]
    },
    "target_class": {
      "enum": [
        "header",
        "index",
        "payload",
        "tail"
      ]
    },
    "magnitude": {
      "enum": [
        "1B",
        "256B",
        "4KB"
      ]
    },
    "result_class": {
      "enum": [
        "SUCCESS",
        "PARTIAL",
        "REFUSED",
        "STRUCTURAL_FAIL",
        "TOOL_ERROR"
      ]
    },
    "failure_stage": {
      "enum": [
        "NONE",
        "PRE_EXTRACT",
        "EXTRACTION",
        "UNKNOWN"
      ]
    },
    "diagnostic_specificity": {
      "enum": [
        "NONE",
        "GENERIC",
        "STRUCTURAL",
        "PRECISE"
      ]
    },
    "evidence_strength": {
      "enum": [
        "structured_json",
        "stdout_stderr",
        "mixed"
      ]
    },
    "evidence_quality": {
      "enum": [
        "stdout_only",
        "stdout_and_stderr",
        "structured_json_result"
      ]
    },
    "normalized_run_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "dataset",
        "format",
        "corruption_type",
        "target_class",
        "magnitude",
        "magnitude_bytes",
        "seed",
        "tool_kind",
        "exit_code",
        "has_json_result",
        "result_completeness",
        "detected_pre_extract",
        "failure_stage",
        "result_class",
        "diagnostic_specificity",
        "normalization_notes",
        "files_expected",
        "files_recovered",
        "files_missing",
        "bytes_expected",
        "bytes_recovered",
        "recovery_ratio_files",
        "recovery_ratio_bytes",
        "blast_radius_class",
        "recovery_evidence_strength"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "minLength": 1
        },
        "dataset": {
          "$ref": "#/$defs/dataset"
        },
        "format": {
          "$ref": "#/$defs/archive_format"
        },
        "corruption_type": {
          "$ref": "#/$defs/corruption_type"
        },
        "target_class": {
          "$ref": "#/$defs/target_class"
        },
        "magnitude": {
          "$ref": "#/$defs/magnitude"
        },
        "magnitude_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "tool_kind": {
          "$ref": "#/$defs/archive_format"
        },
        "exit_code": {
          "type": "integer"
        },
        "has_json_result": {
          "type": "boolean"
        },
        "result_completeness": {
          "$ref": "#/$defs/evidence_quality"
        },
        "detected_pre_extract": {
          "type": "boolean"
        },
        "failure_stage": {
          "$ref": "#/$defs/failure_stage"
        },
        "result_class": {
          "$ref": "#/$defs/result_class"
        },
        "diagnostic_specificity": {
          "$ref": "#/$defs/diagnostic_specificity"
        },
        "normalization_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_expected": {
          "type": "integer",
          "minimum": 0
        },
        "files_recovered": {
          "type": "integer",
          "minimum": 0
        },
        "files_missing": {
          "type": "integer",
          "minimum": 0
        },
        "bytes_expected": {
          "type": "integer",
          "minimum": 0
        },
        "bytes_recovered": {
          "type": "integer",
          "minimum": 0
        },
        "recovery_ratio_files": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "recovery_ratio_bytes": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "blast_radius_class": {
          "$ref": "#/$defs/blast_radius_class"
        },
        "recovery_evidence_strength": {
          "$ref": "#/$defs/recovery_evidence_strength"
        }
      }
    },
    "recovery_evidence_strength": {
      "enum": [
        "FILE_PRESENCE_ONLY",
        "FILE_AND_BYTE_COUNTS",
        "FILE_BYTE_AND_CONTENT_VALIDATION"
      ]
    },
    "blast_radius_class": {
      "enum": [
        "NONE",
        "LOCALIZED",
        "PARTIAL_SET",
        "WIDESPREAD",
        "TOTAL"
      ]
    }
  }
}
