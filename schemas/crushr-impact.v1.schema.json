{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "crushr impact report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corrupted_blocks", "affected_files", "unaffected_files"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "corrupted_blocks": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "uniqueItems": true
    },
    "affected_files": {
      "type": "array",
      "items": { "$ref": "#/$defs/affected_file" }
    },
    "unaffected_files": {
      "type": "array",
      "items": { "$ref": "#/$defs/unaffected_file" }
    }
  },
  "$defs": {
    "file_extent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_id", "offset_in_block", "len"],
      "properties": {
        "block_id": { "type": "integer", "minimum": 0 },
        "offset_in_block": { "type": "integer", "minimum": 0 },
        "len": { "type": "integer", "minimum": 0 }
      }
    },
    "affected_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_id", "path", "affected_extents"],
      "properties": {
        "file_id": { "type": "integer", "minimum": 0 },
        "path": { "type": "string", "minLength": 1 },
        "affected_extents": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_extent" }
        }
      }
    },
    "unaffected_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_id", "path"],
      "properties": {
        "file_id": { "type": "integer", "minimum": 0 },
        "path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
