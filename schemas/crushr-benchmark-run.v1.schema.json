{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.crushr.dev/crushr-benchmark-run.v1.schema.json",
  "title": "crushr benchmark run v1",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_started_unix",
    "environment",
    "dataset_manifest",
    "assumptions",
    "runs"
  ],
  "properties": {
    "schema_version": {
      "const": "crushr-benchmark-run.v1"
    },
    "benchmark_started_unix": {
      "type": "integer"
    },
    "environment": {
      "type": "object",
      "required": [
        "platform",
        "python",
        "uname",
        "cwd"
      ],
      "properties": {
        "platform": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "uname": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dataset",
          "tool",
          "pack_command",
          "extract_command",
          "archive_path",
          "archive_size_bytes",
          "pack_time_ms",
          "extract_time_ms",
          "pack_peak_rss_kb",
          "extract_peak_rss_kb"
        ],
        "properties": {
          "dataset": {
            "enum": [
              "small_mixed_tree",
              "medium_realistic_tree",
              "large_stress_tree"
            ]
          },
          "tool": {
            "enum": [
              "tar_zstd",
              "tar_xz",
              "crushr"
            ]
          },
          "profile": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "full",
              "basic"
            ]
          },
          "pack_command": {
            "type": "string"
          },
          "extract_command": {
            "type": "string"
          },
          "archive_path": {
            "type": "string"
          },
          "archive_size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "pack_time_ms": {
            "type": "integer",
            "minimum": 0
          },
          "extract_time_ms": {
            "type": "integer",
            "minimum": 0
          },
          "pack_peak_rss_kb": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_peak_rss_kb": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "pack_user_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "pack_sys_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_user_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_sys_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "dataset_manifest": {
      "type": "object",
      "required": [
        "manifest_version",
        "generator",
        "seed",
        "fixed_mtime_epoch",
        "xattrs_mode",
        "datasets",
        "dataset_identity"
      ],
      "properties": {
        "manifest_version": {
          "const": "crushr-benchmark-dataset-manifest.v1"
        },
        "generator": {
          "type": "string"
        },
        "seed": {
          "type": "integer"
        },
        "fixed_mtime_epoch": {
          "type": "integer"
        },
        "xattrs_mode": {
          "enum": [
            "off",
            "on"
          ]
        },
        "dataset_identity": {
          "type": "string"
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "file_count",
              "directory_count",
              "symlink_count",
              "total_payload_bytes",
              "xattr_files"
            ],
            "properties": {
              "name": {
                "enum": [
                  "small_mixed_tree",
                  "medium_realistic_tree",
                  "large_stress_tree"
                ]
              },
              "file_count": {
                "type": "integer",
                "minimum": 0
              },
              "directory_count": {
                "type": "integer",
                "minimum": 0
              },
              "symlink_count": {
                "type": "integer",
                "minimum": 0
              },
              "total_payload_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "xattr_files": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "object",
      "required": [
        "level",
        "command_set_id",
        "comparators"
      ],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "command_set_id": {
          "type": "string"
        },
        "comparators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tool",
              "profile"
            ],
            "properties": {
              "tool": {
                "enum": [
                  "tar_zstd",
                  "tar_xz",
                  "crushr"
                ]
              },
              "profile": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "full",
                  "basic"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
