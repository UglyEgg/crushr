{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.crushr.dev/crushr-benchmark-run.v1.schema.json",
  "title": "crushr benchmark run v1",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_started_unix",
    "environment",
    "dataset_manifest",
    "assumptions",
    "dictionary_artifacts",
    "runs"
  ],
  "properties": {
    "schema_version": {
      "const": "crushr-benchmark-run.v1"
    },
    "benchmark_started_unix": {
      "type": "integer"
    },
    "environment": {
      "type": "object",
      "required": [
        "platform",
        "python",
        "uname",
        "cwd"
      ],
      "properties": {
        "platform": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "uname": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dataset",
          "tool",
          "comparator_label",
          "ordering_strategy",
          "content_class_strategy",
          "zstd_level",
          "zstd_strategy",
          "pack_command",
          "extract_command",
          "archive_path",
          "archive_size_bytes",
          "pack_time_ms",
          "extract_time_ms",
          "pack_peak_rss_kb",
          "extract_peak_rss_kb",
          "dictionary",
          "content_classification"
        ],
        "properties": {
          "dataset": {
            "enum": [
              "small_mixed_tree",
              "medium_realistic_tree",
              "large_stress_tree"
            ]
          },
          "tool": {
            "enum": [
              "tar_zstd",
              "tar_zstd_dict",
              "tar_xz",
              "crushr"
            ]
          },
          "profile": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "full",
              "basic"
            ]
          },
          "comparator_label": {
            "type": "string"
          },
          "ordering_strategy": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "lexical",
              "size_ascending",
              "size_descending",
              "extension_grouped",
              "kind_then_extension"
            ]
          },
          "zstd_level": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "content_class_strategy": {
            "type": "string",
            "enum": [
              "off",
              "lightweight_v1"
            ]
          },
          "zstd_strategy": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "default",
              "fast",
              "dfast",
              "greedy",
              "lazy",
              "lazy2",
              "btlazy2",
              "btopt"
            ]
          },
          "pack_command": {
            "type": "string"
          },
          "extract_command": {
            "type": "string"
          },
          "archive_path": {
            "type": "string"
          },
          "archive_size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "pack_time_ms": {
            "type": "integer",
            "minimum": 0
          },
          "extract_time_ms": {
            "type": "integer",
            "minimum": 0
          },
          "pack_peak_rss_kb": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_peak_rss_kb": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "pack_user_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "pack_sys_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_user_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "extract_sys_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "dictionary": {
            "$ref": "#/$defs/dictionary_artifact"
          },
          "content_classification": {
            "$ref": "#/$defs/content_classification"
          }
        },
        "additionalProperties": false
      }
    },
    "dataset_manifest": {
      "type": "object",
      "required": [
        "manifest_version",
        "generator",
        "seed",
        "fixed_mtime_epoch",
        "xattrs_mode",
        "datasets",
        "dataset_identity"
      ],
      "properties": {
        "manifest_version": {
          "const": "crushr-benchmark-dataset-manifest.v1"
        },
        "generator": {
          "type": "string"
        },
        "seed": {
          "type": "integer"
        },
        "fixed_mtime_epoch": {
          "type": "integer"
        },
        "xattrs_mode": {
          "enum": [
            "off",
            "on"
          ]
        },
        "dataset_identity": {
          "type": "string"
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "file_count",
              "directory_count",
              "symlink_count",
              "total_payload_bytes",
              "xattr_files"
            ],
            "properties": {
              "name": {
                "enum": [
                  "small_mixed_tree",
                  "medium_realistic_tree",
                  "large_stress_tree"
                ]
              },
              "file_count": {
                "type": "integer",
                "minimum": 0
              },
              "directory_count": {
                "type": "integer",
                "minimum": 0
              },
              "symlink_count": {
                "type": "integer",
                "minimum": 0
              },
              "total_payload_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "xattr_files": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "object",
      "required": [
        "level",
        "command_set_id",
        "comparators",
        "dictionary_experiment",
        "zstd_experiment",
        "ordering_experiment"
        ,
        "content_class_experiment"
      ],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "command_set_id": {
          "type": "string"
        },
        "comparators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tool",
              "profile",
              "ordering_strategy",
              "content_class_strategy",
              "zstd_level",
              "zstd_strategy"
            ],
            "properties": {
              "tool": {
                "enum": [
                  "tar_zstd",
                  "tar_zstd_dict",
                  "tar_xz",
                  "crushr"
                ]
              },
              "profile": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "full",
                  "basic"
                ]
              },
              "zstd_level": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "ordering_strategy": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "lexical",
                  "size_ascending",
                  "size_descending",
                  "extension_grouped",
                  "kind_then_extension"
                ]
              },
              "zstd_strategy": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "default",
                  "fast",
                  "dfast",
                  "greedy",
                  "lazy",
                  "lazy2",
                  "btlazy2",
                  "btopt"
                ]
              },
              "content_class_strategy": {
                "type": "string",
                "enum": [
                  "off",
                  "lightweight_v1"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "dictionary_experiment": {
          "type": "object",
          "required": [
            "enabled",
            "scope",
            "training_rule"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "scope": {
              "enum": [
                "per_dataset",
                "global"
              ]
            },
            "training_rule": {
              "type": "object",
              "required": [
                "max_samples",
                "sample_bytes",
                "dictionary_size_bytes"
              ],
              "properties": {
                "max_samples": {
                  "type": "integer",
                  "minimum": 1
                },
                "sample_bytes": {
                  "type": "integer",
                  "minimum": 64
                },
                "dictionary_size_bytes": {
                  "type": "integer",
                  "minimum": 256
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "zstd_experiment": {
          "type": "object",
          "required": [
            "baseline_level",
            "level_matrix",
            "strategy_matrix"
          ],
          "properties": {
            "baseline_level": {
              "type": "integer",
              "minimum": 1
            },
            "level_matrix": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 22
              }
            },
            "strategy_matrix": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "default",
                  "fast",
                  "dfast",
                  "greedy",
                  "lazy",
                  "lazy2",
                  "btlazy2",
                  "btopt"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "ordering_experiment": {
          "type": "object",
          "required": [
            "baseline_strategy",
            "strategy_matrix",
            "applies_to_tools"
          ],
          "properties": {
            "baseline_strategy": {
              "const": "lexical"
            },
            "strategy_matrix": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "lexical",
                  "size_ascending",
                  "size_descending",
                  "extension_grouped",
                  "kind_then_extension"
                ]
              }
            },
            "applies_to_tools": {
              "type": "array",
              "items": {
                "enum": [
                  "tar_zstd",
                  "tar_xz",
                  "tar_zstd_dict"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "content_class_experiment": {
          "type": "object",
          "required": [
            "strategy",
            "applies_to_tools",
            "class_labels",
            "classifier_version",
            "sample_bytes",
            "null_byte_binary_threshold",
            "non_text_ratio_binary_threshold"
          ],
          "properties": {
            "strategy": {
              "enum": [
                "off",
                "lightweight_v1"
              ]
            },
            "applies_to_tools": {
              "type": "array",
              "items": {
                "enum": [
                  "tar_zstd",
                  "tar_xz",
                  "tar_zstd_dict"
                ]
              }
            },
            "class_labels": {
              "type": "array",
              "items": {
                "enum": [
                  "structured_text_like",
                  "text_like",
                  "binary_like",
                  "unknown_mixed"
                ]
              }
            },
            "classifier_version": {
              "const": "lightweight_v1"
            },
            "sample_bytes": {
              "const": 4096
            },
            "null_byte_binary_threshold": {
              "const": 1
            },
            "non_text_ratio_binary_threshold": {
              "const": 0.3
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dictionary_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dictionary_artifact"
      }
    }
  },
  "$defs": {
    "content_classification": {
      "type": "object",
      "required": [
        "classifier_version",
        "class_order",
        "class_counts"
      ],
      "properties": {
        "classifier_version": {
          "const": "lightweight_v1"
        },
        "class_order": {
          "type": "array",
          "items": {
            "enum": [
              "structured_text_like",
              "text_like",
              "binary_like",
              "unknown_mixed"
            ]
          }
        },
        "class_counts": {
          "type": "object",
          "required": [
            "structured_text_like",
            "text_like",
            "binary_like",
            "unknown_mixed"
          ],
          "properties": {
            "structured_text_like": {
              "type": "integer",
              "minimum": 0
            },
            "text_like": {
              "type": "integer",
              "minimum": 0
            },
            "binary_like": {
              "type": "integer",
              "minimum": 0
            },
            "unknown_mixed": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "training_provenance": {
      "type": "object",
      "required": [
        "cohort_datasets",
        "training_manifest_id",
        "training_sample_count",
        "training_sample_bytes",
        "selection_rule",
        "training_samples"
      ],
      "properties": {
        "cohort_datasets": {
          "type": "array",
          "items": {
            "enum": [
              "small_mixed_tree",
              "medium_realistic_tree",
              "large_stress_tree"
            ]
          }
        },
        "training_manifest_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "training_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "training_sample_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "selection_rule": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "sort_order": {
              "const": "lexicographic_relative_path"
            },
            "max_samples": {
              "type": "integer",
              "minimum": 1
            },
            "sample_bytes": {
              "type": "integer",
              "minimum": 64
            }
          },
          "required": [
            "sort_order",
            "max_samples",
            "sample_bytes"
          ],
          "additionalProperties": false
        },
        "training_samples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "relpath",
              "size_bytes",
              "content_hash"
            ],
            "properties": {
              "relpath": {
                "type": "string"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "content_hash": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "dictionary_artifact": {
      "type": "object",
      "required": [
        "enabled",
        "scope",
        "cohort_label",
        "dictionary_path",
        "dictionary_content_hash",
        "dictionary_id",
        "dependency_kind",
        "training_provenance"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "scope": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "per_dataset",
            "global"
          ]
        },
        "cohort_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "dictionary_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "dictionary_content_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "dictionary_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "dependency_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "required_dictionary"
          ]
        },
        "training_provenance": {
          "$ref": "#/$defs/training_provenance"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
